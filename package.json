{
  "name": "sidecoin",
  "version": "26.6.8",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev:web": "pnpm --filter @sidecoin/web dev",
    "dev:mobile": "pnpm --filter @sidecoin/mobile start",
    "dev:desktop": "pnpm --filter @sidecoin/desktop dev",
    "dev:wallet": "pnpm --filter @sidecoin/wallet dev",
    "dev:explorer": "pnpm --filter @sidecoin/explorer dev",
    "build:web": "pnpm --filter @sidecoin/web build",
    "build:desktop": "pnpm --filter @sidecoin/desktop build",
    "build:wallet": "pnpm --filter @sidecoin/wallet build",
    "build:explorer": "pnpm --filter @sidecoin/explorer build",
    "build:shared": "pnpm --filter @sidecoin/shared build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@shopify/react-native-skia"
    ]
  }
}
