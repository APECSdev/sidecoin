# .gitignore
# Sidecoin monorepo — root-level ignores

# =============================================================================
# Node / pnpm
# =============================================================================

node_modules/
.pnpm-store/
*.tgz

# =============================================================================
# Build outputs
# =============================================================================

dist/
build/
.output/
.turbo/

# =============================================================================
# IDE / Editor
# =============================================================================

.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# =============================================================================
# OS
# =============================================================================

.DS_Store
Thumbs.db
ehthumbs.db
[Dd]esktop.ini

# =============================================================================
# Environment / secrets
# =============================================================================

.env
.env.*
!.env.example

# =============================================================================
# Logs
# =============================================================================

*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =============================================================================
# Coverage / test artifacts
# =============================================================================

coverage/
*.lcov
lcov.info
*.profraw
*.profdata
test-results/
