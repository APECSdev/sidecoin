{
  "name": "@sidecoin/shared",
  "version": "26.6.8",
  "private": true,
  "license": "MIT",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    },
    "./chain": {
      "types": "./src/chain/index.ts",
      "import": "./src/chain/index.ts",
      "require": "./src/chain/index.ts"
    },
    "./sidechains": {
      "types": "./src/sidechains/index.ts",
      "import": "./src/sidechains/index.ts",
      "require": "./src/sidechains/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "import": "./src/types/index.ts",
      "require": "./src/types/index.ts"
    }
  },
  "scripts": {
    "build": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@noble/hashes": "1.8.0",
    "@scure/base": "1.2.6",
    "@scure/bip32": "1.7.0",
    "@scure/bip39": "1.6.0",
    "@scure/btc-signer": "^2.2.0",
    "bip39": "3.1.0",
    "micro-key-producer": "0.8.6",
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "@types/node": "25.0.3",
    "@vitest/coverage-v8": "4.0.18",
    "typescript": "5.8.3",
    "vitest": "4.0.18"
  }
}
