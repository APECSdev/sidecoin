---
// packages/web/src/pages/chains.astro
//
// Bitcoin Drivechains reference page.
// Served from: sidecoin.app/chains
//
// SEO-optimized educational page explaining:
//   1. What Bitcoin Drivechains (BIP-300/301) are
//   2. Each supported sidechain and its purpose
//   3. How Sidecoin unifies them into a single experience
//   4. Why Drivechains matter for Bitcoin's future
//
// Target keywords (used naturally):
//   Bitcoin sidechains, Drivechains, BIP-300, BIP-301,
//   Bitcoin smart contracts, Bitcoin DeFi, Bitcoin privacy

import BaseLayout from "../layouts/BaseLayout.astro";
import ChainsHero from "../components/chains/ChainsHero.astro";
import ChainsIntro from "../components/chains/ChainsIntro.astro";
import ChainsGrid from "../components/chains/ChainsGrid.astro";
import HowItWorks from "../components/chains/HowItWorks.astro";
import WhyItMatters from "../components/chains/WhyItMatters.astro";
import ChainsFooterCTA from "../components/chains/ChainsFooterCTA.astro";
---

<BaseLayout
  title="Bitcoin Drivechains — Sidecoin Supported Sidechains"
  description="Explore the 8 Bitcoin sidechains supported by Sidecoin at launch. BIP-300/301 Drivechains bring payments, privacy, smart contracts, identity, and more to Bitcoin."
>
  <!-- Hero -->
  <ChainsHero />

  <!-- Intro — What are Drivechains -->
  <ChainsIntro />

  <!-- Chains Grid -->
  <ChainsGrid />

  <!-- How It Works -->
  <HowItWorks />

  <!-- Why It Matters -->
  <WhyItMatters />

  <!-- Footer CTA -->
  <ChainsFooterCTA />
</BaseLayout>
