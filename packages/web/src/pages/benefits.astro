---
// packages/web/src/pages/benefits.astro
//
// Sidecoin PRO benefits page.

import BaseLayout from "../layouts/BaseLayout.astro";

const basic = [
  "L1 wallet",
  "Thunder payments",
  "BitNames identity registration",
  "Swap access",
  "Coin Split Helper",
];

const pro = [
  "All Drivechain platforms",
  "Historical analysis",
  "Hardware signing workflows",
  "Early access to proposed platforms like RISCy",
  "Premium platform dashboards",
  "Advanced wallet insights",
];

const cards = [
  {
    title: "All Platforms",
    body: "PRO unlocks zSide, BitAssets, Photon, Truthcoin, CoinShift, RISCy, and future Drivechain platforms.",
  },
  {
    title: "Historical Analysis",
    body: "Track balances, activity, and performance across L1 and every platform in the Drivechains Financial Hub.",
  },
  {
    title: "Early Access",
    body: "PRO members get first access to proposed platforms and advanced platform workflows.",
  },
  {
    title: "Hardware Workflows",
    body: "Use premium hardware wallet flows for higher-assurance signing and transaction review.",
  },
];
---

<BaseLayout
  title="Sidecoin PRO Benefits — Drivechains Financial Hub"
  description="Unlock the full Drivechains Financial Hub with Sidecoin PRO: all platforms, historical analysis, hardware workflows, and early access."
>
  <main>
    <section class="mx-auto max-w-5xl px-6 py-24 text-center">
      <p class="text-sm font-black uppercase tracking-[0.3em] text-amber-400">
        Sidecoin PRO
      </p>
      <h1 class="mt-4 text-5xl font-black tracking-tight md:text-7xl">
        Unlock the full
        <span class="bg-gradient-to-r from-amber-300 to-ecash-400 bg-clip-text text-transparent">
          Drivechains Financial Hub
        </span>
      </h1>
      <p class="mx-auto mt-6 max-w-3xl text-lg leading-8 text-gray-400">
        Basic gives everyone L1, Thunder, BitNames, Swap, and coin splitting.
        PRO unlocks every platform, historical analysis, hardware workflows,
        and early access to proposed platforms like RISCy.
      </p>

      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a
          href="/pro"
          class="rounded-xl bg-amber-500 px-8 py-4 text-sm font-black text-gray-950 no-underline transition-colors hover:bg-amber-400 hover:no-underline"
        >
          Upgrade to PRO
        </a>
        <a
          href="https://wallet.sidecoin.app/"
          class="rounded-xl border border-gray-700 bg-gray-900 px-8 py-4 text-sm font-bold text-gray-200 no-underline transition-colors hover:border-ecash-500 hover:text-white hover:no-underline"
        >
          Open Wallet
        </a>
      </div>
    </section>

    <section class="mx-auto grid max-w-5xl gap-4 px-6 pb-20 md:grid-cols-4">
      {cards.map((card) => (
        <div class="rounded-2xl border border-gray-800 bg-gray-900 p-5">
          <h2 class="font-bold text-white">{card.title}</h2>
          <p class="mt-2 text-sm leading-6 text-gray-400">{card.body}</p>
        </div>
      ))}
    </section>

    <section class="mx-auto grid max-w-5xl gap-6 px-6 pb-24 md:grid-cols-2">
      <div class="rounded-2xl border border-gray-800 bg-gray-900 p-6">
        <h2 class="text-2xl font-black">Basic</h2>
        <p class="mt-2 text-sm text-gray-400">
          Open access for the core wallet and acquisition features.
        </p>
        <ul class="mt-6 space-y-3">
          {basic.map((item) => (
            <li class="text-sm text-gray-300">
              <span class="text-ecash-400">✓</span> {item}
            </li>
          ))}
        </ul>
      </div>

      <div class="rounded-2xl border border-amber-500/40 bg-amber-950/10 p-6">
        <h2 class="text-2xl font-black text-amber-400">PRO</h2>
        <p class="mt-2 text-sm text-gray-400">
          Premium access to the complete Drivechains Financial Hub.
        </p>
        <ul class="mt-6 space-y-3">
          {pro.map((item) => (
            <li class="text-sm text-gray-300">
              <span class="text-amber-400">✓</span> {item}
            </li>
          ))}
        </ul>
      </div>
    </section>
  </main>
</BaseLayout>
