---
// packages/web/src/pages/pro.astro
//
// Sidecoin Pro — Founding Member conversion page.
// Served from: sidecoin.app/pro

import BaseLayout from "../layouts/BaseLayout.astro";
import ProHero from "../components/pro/ProHero.astro";
import ValueProps from "../components/pro/ValueProps.astro";
import PricingSection from "../components/pro/PricingSection.astro";
import FoundingMember from "../components/pro/FoundingMember.astro";
import AlphaCircle from "../components/pro/AlphaCircle.astro";
import UrgencyBanner from "../components/pro/UrgencyBanner.astro";
import PaymentFlow from "../components/pro/PaymentFlow.vue";
import FAQ from "../components/pro/FAQ.astro";
import ProFooterCTA from "../components/pro/ProFooterCTA.astro";
---

<BaseLayout
  title="Sidecoin Pro — Founding Member Access"
  description="Upgrade to Sidecoin Pro. Reduce fees, unlock advanced features, and become a Founding Member of the Bitcoin Drivechain Financial Hub. Crypto payments only."
>
  <!-- Hero -->
  <ProHero />

  <!-- Value Propositions -->
  <ValueProps />

  <!-- Pricing Plans -->
  <PricingSection />

  <!-- Full-page Checkout (Vue, client-only) -->
  <PaymentFlow client:only="vue" />

  <!-- What is a Founding Member -->
  <FoundingMember />

  <!-- Alpha Circle -->
  <AlphaCircle />

  <!-- Urgency / Countdown -->
  <UrgencyBanner />

  <!-- FAQ -->
  <FAQ />

  <!-- Final CTA -->
  <ProFooterCTA />

  <!-- ─── Footer ──────────────────────────────────────────── -->
  <footer class="border-t border-gray-800">
    <div class="mx-auto max-w-5xl px-6 py-12">
      <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
        <div>
          <p class="text-lg font-bold text-ecash-400">
            <span aria-hidden="true">SidΞcoin</span><span class="sr-only">Sidecoin</span>
          </p>
          <p class="text-sm text-gray-500">
            eCash Drivechains Wallet · Open Source · MIT License
          </p>
        </div>
        <div class="flex gap-6 text-sm text-gray-400">
          <a href="https://github.com/nyusternie/sidecoin" class="hover:text-white">GitHub</a>
          <a href="https://ecash.com" class="hover:text-white">eCash</a>
          <a href="https://bip300.info" class="hover:text-white">BIP-300</a>
        </div>
      </div>
      <p class="mt-8 text-center text-xs text-gray-600">
        © 2026 0xShomari. Not affiliated with eCash or Bitcoin ABC.
      </p>
    </div>
  </footer>
</BaseLayout>
