---
// packages/web/src/components/founders/FoundersHero.astro
//
// Hero section for the /founders page.
// Headline, subheadline, supporting text, and social-proof hint.
---

<header class="relative overflow-hidden">
  <!-- Background gradient — amber/gold tinted for Founding Member branding -->
  <div class="absolute inset-0 bg-gradient-to-b from-amber-950/20 via-gray-950 to-gray-950"></div>

  <div class="relative mx-auto max-w-5xl px-6 pb-16 pt-24 text-center md:pt-32">

    <!-- Badge -->
    <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-amber-800/50 bg-amber-950/30 px-4 py-1.5">
      <span class="h-2 w-2 rounded-full bg-amber-400 animate-pulse"></span>
      <span class="text-xs font-semibold uppercase tracking-widest text-amber-400">
        Live Leaderboard
      </span>
    </div>

    <h1 class="text-5xl font-extrabold tracking-tight md:text-7xl">
      <span class="bg-gradient-to-r from-amber-400 via-orange-400 to-amber-500 bg-clip-text text-transparent">
        Founding Members
      </span>
    </h1>

    <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-300 md:text-xl">
      Early participants in the Bitcoin Drivechain Financial Hub
    </p>

    <p class="mx-auto mt-4 max-w-xl text-base text-gray-500">
      Founding Members secure reduced fees, early access, and permanent
      recognition before Drivechain activation.
    </p>

    <!-- Navigation hints -->
    <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
      <a
        href="#leaderboard"
        class="rounded-lg border border-gray-700 bg-gray-900 px-6 py-3 text-sm font-semibold text-gray-300 transition-colors hover:border-amber-700 hover:text-white"
      >
        View Leaderboard
      </a>
      <a
        href="/pro"
        class="rounded-lg bg-amber-500 px-6 py-3 text-sm font-bold text-gray-950 shadow-lg shadow-amber-500/20 transition-all hover:bg-amber-400 hover:shadow-amber-400/30"
      >
        Become a Founding Member
      </a>
    </div>

  </div>
</header>
