---
// packages/web/src/components/founders/LiveStatsBar.astro
//
// Displays three live stats:
//   1. Total Founders (fetched client-side from our API)
//   2. Alpha Circle Cut Line (top 20%, computed server-side)
//   3. Countdown to August 21, 2026
//
// Values are populated by client-side JavaScript on mount
// and fall back to placeholder text ("—") if JS is disabled
// or the API is unreachable.
---

<section class="border-y border-gray-800 bg-gray-900/40">
  <div class="mx-auto max-w-5xl px-6 py-8">
    <div class="grid gap-6 sm:grid-cols-3">

      <!-- Total Founders -->
      <div class="text-center">
        <p class="text-xs uppercase tracking-widest text-gray-500">
          Total Founders
        </p>
        <p class="mt-2 font-mono text-3xl font-bold text-white" id="stats-total-founders">
          —
        </p>
      </div>

      <!-- Alpha Circle Cut Line -->
      <div class="text-center">
        <p class="text-xs uppercase tracking-widest text-gray-500">
          Alpha Circle Cut Line
        </p>
        <p class="mt-2 font-mono text-3xl font-bold text-amber-400" id="stats-cut-line">
          —
        </p>
      </div>

      <!-- Countdown -->
      <div class="text-center">
        <p class="text-xs uppercase tracking-widest text-gray-500">
          Positions Lock In
        </p>
        <p class="mt-2 font-mono text-3xl font-bold text-white" id="stats-countdown">
          —
        </p>
      </div>

    </div>
  </div>
</section>

<!-- Stats bar script — vanilla JS, no framework dependency -->
<script>
  const FORK_DATE = new Date("2026-08-21T15:00:00Z").getTime();

  // Same-origin API by default; override with PUBLIC_API_BASE in dev.
  const API_BASE = import.meta.env.PUBLIC_API_BASE || "/v1";

  const $totalFounders = document.getElementById("stats-total-founders");
  const $cutLine = document.getElementById("stats-cut-line");
  const $countdown = document.getElementById("stats-countdown");

  // ── Countdown timer ──────────────────────────────────────

  function pad(n: number): string {
    return n.toString().padStart(2, "0");
  }

  function tickCountdown(): void {
    const diff = FORK_DATE - Date.now();

    if (diff <= 0) {
      if ($countdown) $countdown.textContent = "LIVE";
      return;
    }

    const d = Math.floor(diff / (1000 * 60 * 60 * 24));
    const h = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
    const s = Math.floor((diff % (1000 * 60)) / 1000);

    if ($countdown) {
      $countdown.textContent = `${d}d ${pad(h)}:${pad(m)}:${pad(s)}`;
    }
  }

  tickCountdown();
  setInterval(tickCountdown, 1000);

  // ── Founder stats (live from our API) ────────────────────
  //
  // GET /v1/founders?limit=1 returns { total, cutLine, ... }. We only need the
  // aggregate fields, so we request the smallest possible page. The cut line is
  // computed server-side (live 20%), so we render it verbatim.

  function renderFounderStats(total: number, cutLine: number): void {
    if ($totalFounders) {
      $totalFounders.textContent = total.toLocaleString();
    }
    if ($cutLine) {
      $cutLine.textContent = `#${cutLine.toLocaleString()}`;
    }
  }

  async function loadFounderStats(): Promise<void> {
    try {
      const res = await fetch(`${API_BASE}/founders?limit=1`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();

      const total = typeof data.total === "number" ? data.total : 0;
      // Prefer the server's live cut line; fall back to the 20% rule locally.
      const cutLine =
        typeof data.cutLine === "number"
          ? data.cutLine
          : Math.max(1, Math.ceil(total * 0.2));

      renderFounderStats(total, cutLine);
    } catch (err) {
      // Non-fatal: leave the "—" placeholders in place.
      console.error("[founders:stats] failed to load", err);
    }
  }

  loadFounderStats();
</script>
