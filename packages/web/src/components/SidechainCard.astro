---
// packages/web/src/components/SidechainCard.astro
//
// Static card for a sidechain on the landing page.

interface Props {
  slotNumber: number;
  name: string;
  description: string;
  status: string;
}

const { slotNumber, name, description, status } = Astro.props;

const isActive = status === "active";
---

<div class="rounded-xl border border-gray-800 bg-gray-900/60 p-5 backdrop-blur-sm transition-colors hover:border-ecash-800">
  <div class="flex items-center justify-between">
    <h3 class="text-lg font-semibold text-white">{name}</h3>
    <span
      class:list={[
        "rounded-full px-2.5 py-0.5 text-xs font-medium",
        isActive ? "bg-ecash-900/50 text-ecash-400" : "bg-gray-800 text-gray-500",
      ]}
    >
      {isActive ? "Active" : "Proposed"}
    </span>
  </div>
  <p class="mt-2 text-sm leading-relaxed text-gray-400">{description}</p>
  <p class="mt-3 font-mono text-xs text-gray-600">Slot {slotNumber}</p>
</div>
