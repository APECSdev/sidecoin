---
// packages/web/src/components/chains/ChainDetail.astro
//
// Reusable detail block for a sidechain.
// Used standalone or inside a ChainCard expansion.
// Accepts the same data as ChainCard.

interface Props {
  name: string;
  description: string;
  features?: string[];
  slotNumber: number | null;
}

const {
  name,
  description,
  features = [],
  slotNumber,
} = Astro.props;

const slotLabel = slotNumber == null ? "TBD" : String(slotNumber);
---

<div class="rounded-xl border border-gray-800 bg-gray-950 p-6">
  <h4 class="text-base font-semibold text-white">{name}</h4>

  <p class="mt-3 text-sm leading-relaxed text-gray-400">
    {description}
  </p>

  {features.length > 0 && (
    <ul class="mt-4 space-y-2">
      {features.map((f) => (
        <li class="flex items-start gap-3 text-sm text-gray-300">
          <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-ecash-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span>{f}</span>
        </li>
      ))}
    </ul>
  )}

  <p class="mt-4 font-mono text-xs text-gray-600">
    BIP-300 Slot {slotLabel}
  </p>
</div>
