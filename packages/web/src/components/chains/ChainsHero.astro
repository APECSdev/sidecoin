---
// packages/web/src/components/chains/ChainsHero.astro
//
// Hero section for the /chains page.
// Headline, subheadline, supporting text.
---

<header class="relative overflow-hidden">
  <!-- Background gradient — ecash green tint for ecosystem branding -->
  <div class="absolute inset-0 bg-gradient-to-b from-ecash-950/20 via-gray-950 to-gray-950"></div>

  <div class="relative mx-auto max-w-5xl px-6 pb-16 pt-24 text-center md:pt-32">

    <!-- Badge -->
    <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-ecash-800/50 bg-ecash-950/30 px-4 py-1.5">
      <span class="h-2 w-2 rounded-full bg-ecash-400 animate-pulse"></span>
      <span class="text-xs font-semibold uppercase tracking-widest text-ecash-400">
        BIP-300 / BIP-301
      </span>
    </div>

    <h1 class="text-5xl font-extrabold tracking-tight md:text-7xl">
      Bitcoin
      <span class="bg-gradient-to-r from-amber-400 via-orange-400 to-amber-500 bg-clip-text text-transparent">
        Drivechains
      </span>
    </h1>

    <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-300 md:text-xl">
      A modular financial system built on Bitcoin's security
    </p>

    <p class="mx-auto mt-4 max-w-xl text-base text-gray-500">
      Sidecoin connects multiple Drivechains into a unified financial
      hub — bringing payments, privacy, smart contracts, identity,
      and more to Bitcoin.
    </p>

    <!-- Navigation hints -->
    <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
      <a
        href="#chains"
        class="rounded-lg border border-gray-700 bg-gray-900 px-6 py-3 text-sm font-semibold text-gray-300 transition-colors hover:border-ecash-700 hover:text-white"
      >
        Explore Chains
      </a>
      <a
        href="/pro"
        class="rounded-lg bg-amber-500 px-6 py-3 text-sm font-bold text-gray-950 shadow-lg shadow-amber-500/20 transition-all hover:bg-amber-400 hover:shadow-amber-400/30"
      >
        Upgrade to Pro
      </a>
    </div>

  </div>
</header>
