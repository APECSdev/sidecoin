---
// packages/web/src/components/pro/ProFooterCTA.astro
//
// Final call-to-action before the footer.
// Reinforces urgency and conversion messaging.
---

<section class="border-t border-gray-800 bg-gradient-to-t from-amber-950/10 to-gray-950">
  <div class="mx-auto max-w-3xl px-6 py-20 text-center">

    <h2 class="text-3xl font-bold md:text-4xl">
      Secure Your
      <span class="text-amber-400">Founder Number</span>
    </h2>

    <p class="mx-auto mt-4 max-w-xl text-gray-400">
      Join the earliest supporters of the Bitcoin Drivechain ecosystem.
      Founding Member pricing won't last forever.
    </p>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
      <a
        href="#pricing"
        class="rounded-lg bg-amber-500 px-10 py-4 text-base font-bold text-gray-950 no-underline shadow-lg shadow-amber-500/20 transition-all hover:bg-amber-400 hover:shadow-amber-400/30 hover:no-underline"
      >
        Get Founding Access
      </a>
      <a
        href="/"
        class="rounded-lg border border-gray-700 bg-gray-900 px-8 py-4 text-base font-semibold text-gray-300 no-underline transition-colors hover:border-gray-600 hover:text-white hover:no-underline"
      >
        Learn More About Sidecoin
      </a>
    </div>

    <p class="mt-6 text-xs text-gray-600">
      Crypto payments only · No accounts required · Instant activation
    </p>
  </div>
</section>
