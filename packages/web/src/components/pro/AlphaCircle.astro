---
// packages/web/src/components/pro/AlphaCircle.astro
//
// Alpha Circle section — explains the top 10% tier
// and shows dynamic cut-line messaging.

const benefits = [
  "Upgraded Founder badge (Alpha variant)",
  "Exclusive access to Nightly builds",
  "Earliest access to new features and sidechains",
  "Access to a private, wallet-gated discussion relay",
];

// Placeholder values — replaced by API data at runtime
const currentCutLine = "XXX";
---

<section class="mx-auto max-w-5xl px-6 py-20">
  <div class="rounded-2xl border border-amber-800/30 bg-gradient-to-br from-amber-950/20 via-gray-950 to-gray-950 p-10 md:p-14">

    <!-- Header -->
    <div class="text-center">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-amber-700/40 bg-amber-950/30 px-4 py-1.5">
        <span class="text-xs font-bold uppercase tracking-widest text-amber-400">
          Exclusive Tier
        </span>
      </div>

      <h2 class="text-3xl font-bold md:text-4xl">
        <span class="bg-gradient-to-r from-amber-300 to-orange-400 bg-clip-text text-transparent">
          Alpha Circle
        </span>
      </h2>

      <p class="mx-auto mt-4 max-w-2xl text-gray-400 leading-relaxed">
        The top 10% of Founding Members at the time of Drivechain activation
        (August 21, 2026) will be inducted into the Alpha Circle —
        an exclusive group of Sidecoin's earliest and most committed supporters.
      </p>

      <p class="mx-auto mt-4 max-w-2xl rounded-xl border border-amber-500/40 bg-amber-950/20 p-4 text-sm leading-6 text-amber-100">
        Alpha Circle eligibility requires Yearly PRO. Monthly PRO unlocks
        Sidecoin PRO wallet features, but does not qualify for Alpha Circle or
        Founder Leaderboard placement.
      </p>
    </div>

    <!-- Benefits grid -->
    <div class="mt-12 grid gap-4 sm:grid-cols-2">
      {benefits.map((b) => (
        <div class="flex items-start gap-3 rounded-xl border border-gray-800 bg-gray-900/60 p-5">
          <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
          </svg>
          <span class="text-sm text-gray-300">{b}</span>
        </div>
      ))}
    </div>

    <!-- Cut line indicator -->
    <div class="mt-12 flex flex-col items-center gap-2 rounded-xl border border-gray-800 bg-gray-950 p-6 text-center">
      <p class="text-xs uppercase tracking-widest text-gray-500">
        Current Cut Line
      </p>
      <p class="font-mono text-3xl font-bold text-amber-400" id="alpha-cut-line">
        #{currentCutLine}
      </p>
      <p class="text-xs text-gray-500">
        Your position will be determined at activation
      </p>
    </div>

  </div>
</section>
