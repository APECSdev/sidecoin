---
// packages/web/src/components/pro/FAQ.astro
//
// Frequently Asked Questions section for the /pro page.
// Uses native <details> elements — no JavaScript required.

const faqs = [
  {
    question: "What is Sidecoin Pro?",
    answer:
      "Sidecoin Pro is the premium tier of the Sidecoin wallet. Pro members get reduced fees on swaps and bridging, early access to new sidechains and features, advanced tools, and access to the full Drivechains Financial Hub.",
  },
  {
    question: "What is a Founding Member?",
    answer:
      "Founding Members are early supporters who join with Yearly PRO before Drivechain activation on August 21, 2026. Each eligible Founding Member receives a unique Founder number and permanent recognition across Sidecoin platforms.",
  },
  {
    question: "Does Monthly PRO qualify for the Founder Leaderboard?",
    answer:
      "No. Monthly PRO unlocks Sidecoin PRO wallet features, but Founder Leaderboard placement and Alpha Circle eligibility require Yearly PRO.",
  },
  {
    question: "What is Alpha Circle?",
    answer:
      "Alpha Circle is an exclusive tier within the Founding Members. The top 10% of eligible Yearly PRO Founding Members at the time of Drivechain activation will be inducted into the Alpha Circle, receiving an upgraded badge, Nightly build access, and entry to a private wallet-gated discussion relay.",
  },
  {
    question: "How do crypto payments work?",
    answer:
      "We use a white-label crypto checkout powered by our own payment API. Select your plan, choose your preferred cryptocurrency, and send the exact amount to the provided address. Payments are confirmed on-chain — no accounts or credit cards required.",
  },
  {
    question: "When does Founding Member pricing end?",
    answer:
      "Founding Member eligibility is available until Drivechain activation on August 21, 2026. After that date, Founder Leaderboard placement and Alpha Circle eligibility will no longer be available to new members.",
  },
  {
    question: "Will prices increase after launch?",
    answer:
      "Yes. Current pricing is 5 USD per month or 36 USD per year. After Drivechain activation, PRO pricing may increase to reflect the full value of the platform.",
  },
];
---

<section class="mx-auto max-w-3xl px-6 py-20">
  <h2 class="text-center text-3xl font-bold md:text-4xl">
    Frequently Asked <span class="text-amber-400">Questions</span>
  </h2>

  <div class="mt-12 space-y-4">
    {faqs.map((faq) => (
      <details class="group rounded-xl border border-gray-800 bg-gray-900/40 transition-colors hover:border-gray-700">
        <summary class="flex cursor-pointer items-center justify-between px-6 py-5 text-left text-white font-medium">
          <span>{faq.question}</span>
          <svg
            class="h-5 w-5 flex-shrink-0 text-gray-500 transition-transform group-open:rotate-180"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="border-t border-gray-800 px-6 py-5">
          <p class="text-sm leading-relaxed text-gray-400">{faq.answer}</p>
        </div>
      </details>
    ))}
  </div>
</section>
