# packages/desktop/.gitignore
# Sidecoin Desktop — Tauri + Vue + Rust

# =============================================================================
# Node / Frontend
# =============================================================================

node_modules/
dist/
*.local

# Vite
*.timestamp-*

# Coverage (frontend)
coverage/

# =============================================================================
# Rust / Cargo / Tauri
# =============================================================================

src-tauri/target/
src-tauri/Cargo.lock

# Tauri generated
src-tauri/gen/
src-tauri/icons/icon.ico
src-tauri/icons/icon.icns
src-tauri/icons/*.png
!src-tauri/icons/.gitkeep

# =============================================================================
# Specta / generated bindings
# =============================================================================

src/bindings.ts

# =============================================================================
# IDE / Editor
# =============================================================================

.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# =============================================================================
# OS
# =============================================================================

.DS_Store
Thumbs.db
ehthumbs.db
[Dd]esktop.ini

# =============================================================================
# Testing / CI artifacts
# =============================================================================

*.lcov
lcov.info
*.profraw
*.profdata
test-results/
playwright-report/

# =============================================================================
# Logs
# =============================================================================

*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =============================================================================
# Environment / secrets
# =============================================================================

.env
.env.*
!.env.example

# =============================================================================
# WebDriver / E2E
# =============================================================================

wdio-logs/
allure-results/
allure-report/
