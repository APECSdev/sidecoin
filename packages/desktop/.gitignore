# packages/desktop/.gitignore
# Sidecoin Desktop — Tauri + Vue + Rust

# =============================================================================
# Node / Frontend
# =============================================================================

node_modules/
dist/
*.local

# Vite
*.timestamp-*

# Coverage (frontend)
coverage/

# =============================================================================
# Rust / Cargo / Tauri
# =============================================================================

src-tauri/target/
# NOTE: Cargo.lock is deliberately tracked in git.
# Tauri is a binary/application project (not a library), so the lockfile
# must be committed to ensure deterministic builds. CI uses `cargo build
# --locked` which requires Cargo.lock to exist. Without it, Cargo resolves
# the latest compatible transitive dependencies (e.g. tauri-runtime),
# which can introduce breaking trait changes and fail compilation.
# See: https://doc.rust-lang.org/cargo/faq.html#why-have-cargolock-in-version-control

# Tauri generated
src-tauri/gen/
# NOTE: Icon files (32x32.png, 128x128.png, 128x128@2x.png, icon.icns,
# icon.ico) are deliberately tracked in git. Tauri's generate_context!()
# proc macro reads them at compile time. If they are missing, compilation
# fails with "icon file not found". Only icon.png (not referenced in
# tauri.conf.json) is excluded.

# =============================================================================
# Specta / generated bindings
# =============================================================================

src/bindings.ts

# =============================================================================
# IDE / Editor
# =============================================================================

.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# =============================================================================
# OS
# =============================================================================

.DS_Store
Thumbs.db
ehthumbs.db
[Dd]esktop.ini

# =============================================================================
# Testing / CI artifacts
# =============================================================================

*.lcov
lcov.info
*.profraw
*.profdata
test-results/
playwright-report/

# =============================================================================
# Logs
# =============================================================================

*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =============================================================================
# Environment / secrets
# =============================================================================

.env
.env.*
!.env.example

# =============================================================================
# WebDriver / E2E
# =============================================================================

wdio-logs/
allure-results/
allure-report/
